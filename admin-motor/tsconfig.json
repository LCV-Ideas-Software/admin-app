{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types", "node"],
    "tsBuildInfoFile": "../node_modules/.tmp/tsconfig.admin-motor.tsbuildinfo",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "../vitest.admin-motor.config.ts"],
  "exclude": [".wrangler", "dist"]
}
