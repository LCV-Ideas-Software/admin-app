{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "admin-motor",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-06",
  "workers_dev": false,
  "compatibility_flags": ["nodejs_compat"],
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": true,
      "head_sampling_rate": 1
    },
    "traces": {
      "enabled": true
    }
  },
  "vars": {
    "MAESTRO_SECRET_STORE_ID": "df90c0935ba1460899c3c2c457548a90"
  },
